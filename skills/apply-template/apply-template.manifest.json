{
  "version": "0.1.0",
  "description": "File classification for ai-env template application. Used by /apply-template skill.",
  "copy_if_absent": [
    ".claude/agents/",
    ".claude/rules/",
    ".claude/skills/",
    ".codex/config.toml",
    "CLAUDE.md",
    ".claudeignore",
    ".mcp.json",
    "ai-workspace/plans/TEMPLATE.md",
    "ai-workspace/decisions/TEMPLATE.md",
    "commitlint.config.mjs",
    "lefthook.yml",
    ".tool-versions",
    ".github/workflows/ci.yml",
    ".github/workflows/claude.yml",
    ".github/workflows/claude-code-review.yml",
    ".github/workflows/commitlint.yml",
    "tsconfig.test.json"
  ],
  "smart_merge": [
    "AGENTS.md",
    ".claude/settings.json",
    "package.json",
    "tsconfig.json",
    "biome.json",
    ".gitignore"
  ],
  "skip": [
    "src/",
    "agentic-env/",
    "README.md",
    "pnpm-lock.yaml",
    "node_modules/",
    ".claude/settings.local.json",
    "apply-template.manifest.json",
    ".github/template-cleanup.sh"
  ]
}
